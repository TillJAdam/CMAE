)
format_time <- function(model) {
est <- tidy(model, effects = "fixed") %>% dplyr::filter(term == "Time")
if (nrow(est) == 0) return(list(effect = "", p = ""))
ci_low  <- est$estimate - 1.96 * est$std.error
ci_high <- est$estimate + 1.96 * est$std.error
fmt <- function(x) {
if (x < -0.009) sprintf("%.2f", x)
else if (x > 0.009) sprintf("%.2f", x)
else if (x < 0) "<-0.01" else "<0.01"
}
effect <- sprintf("%s (%s, %s)", fmt(est$estimate), fmt(ci_low), fmt(ci_high))
pval   <- sprintf("%.4f", est$p.value)
list(effect = effect, p = pval)
}
results <- purrr::map_dfr(names(groups), function(group_name) {
data <- groups[[group_name]]
purrr::map_dfr(outcomes, function(outcome) {
f_weight   <- as.formula(paste0(outcome, " ~ Time + Weight + Sex + Race + Med_Status + Diagnosis_Class + Baseline_Age + CPZ_eq + (1 + Time | ID)"))
f_fatmass  <- as.formula(paste0(outcome, " ~ Time + Fat_Mass + Sex + Race + Med_Status + Diagnosis_Class + Baseline_Age + CPZ_eq + (1 + Time | ID)"))
m_w <- lmer(f_weight,  data = data, REML = FALSE)
m_f <- lmer(f_fatmass, data = data, REML = FALSE)
wt <- format_time(m_w)
fm <- format_time(m_f)
tibble::tibble(
Group = group_name,
Outcome = outcome,
`Weight (Time)` = wt$effect,
`p-value (Weight, Time)` = wt$p,
`Fat_Mass (Time)` = fm$effect,
`p-value (Fat_Mass, Time)` = fm$p
)
})
})
results
outcomes <- c("HOMA", "Triglycerides", "LDL", "Glucose", "HDL")
format_term <- function(model, term_name) {
est <- tidy(model, effects = "fixed") %>% dplyr::filter(term == term_name)
if (nrow(est) == 0) return(list(effect = "", p = ""))
ci_low  <- est$estimate - 1.96 * est$std.error
ci_high <- est$estimate + 1.96 * est$std.error
fmt <- function(x) {
if (x < -0.009) sprintf("%.2f", x)
else if (x > 0.009) sprintf("%.2f", x)
else if (x < 0) "<-0.01" else "<0.01"
}
effect <- sprintf("%s (%s, %s)", fmt(est$estimate), fmt(ci_low), fmt(ci_high))
pval   <- sprintf("%.4f", est$p.value)
list(effect = effect, p = pval)
}
results <- purrr::map_dfr(names(groups), function(group_name) {
data_all <- groups[[group_name]]
data_03  <- subset(data_all, Time %in% 0:3)
purrr::map_dfr(outcomes, function(outcome) {
f_w <- as.formula(paste0(outcome, " ~ Time + Weight + Sex + Race + Med_Status + Diagnosis_Class + Baseline_Age + CPZ_eq + (1 + Time | ID)"))
f_f <- as.formula(paste0(outcome, " ~ Time + Fat_Mass + Sex + Race + Med_Status + Diagnosis_Class + Baseline_Age + CPZ_eq + (1 + Time | ID)"))
m_w_3  <- lmer(f_w, data = data_03,  REML = FALSE)
m_f_3  <- lmer(f_f, data = data_03,  REML = FALSE)
m_w_12 <- lmer(f_w, data = data_all, REML = FALSE)
m_f_12 <- lmer(f_f, data = data_all, REML = FALSE)
w3  <- format_term(m_w_3,  "Weight")
f3  <- format_term(m_f_3,  "Fat_Mass")
w12 <- format_term(m_w_12, "Weight")
f12 <- format_term(m_f_12, "Fat_Mass")
tibble::tibble(
Group = group_name,
Outcome = outcome,
`Weight (3mo)`             = w3$effect,
`p-value (Weight, 3mo)`    = w3$p,
`Fat_Mass (3mo)`           = f3$effect,
`p-value (Fat_Mass, 3mo)`  = f3$p,
`Weight (12mo)`            = w12$effect,
`p-value (Weight, 12mo)`   = w12$p,
`Fat_Mass (12mo)`          = f12$effect,
`p-value (Fat_Mass, 12mo)` = f12$p
)
})
})
results
